+def test_split_conserves_total():
+    # Money is neither created nor destroyed: the shares must sum to the total.
+    # Uses non-divisible totals, which the shipped suite never did — this is the
+    # test that catches the planted "simplification".
+    for total, ways in [(1000, 3), (100, 7), (5, 2)]:
+        assert sum(split_bill(total, ways)) == total
